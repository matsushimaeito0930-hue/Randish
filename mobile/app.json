{
  "expo": {
    "name": "RANDISH",
    "slug": "randish",
    "version": "1.0.0",
    "scheme": "randish",
    "orientation": "portrait",
    "icon": "./assets/randish-logo-square1.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/randish-logo-square1.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8fafc"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "プロフィール画像や食事の写真を選ぶために写真ライブラリへのアクセスを使用します。",
          "cameraPermission": "食事の写真を撮ってアルバムに残すためにカメラを使用します。"
        }
      ],
      "expo-apple-authentication",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "近くのお店を探してルーレットで選ぶために現在地を使用します。"
        }
      ],
      "expo-secure-store"
    ],
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "食事の写真を撮ってアルバムに残すためにカメラを使用します。",
        "NSLocationWhenInUseUsageDescription": "近くのお店を探してルーレットで選ぶために現在地を使用します。",
        "NSPhotoLibraryUsageDescription": "プロフィール画像や食事の写真を選ぶために写真ライブラリへのアクセスを使用します。",
        "NSPhotoLibraryAddUsageDescription": "撮影した食事の写真をアルバムに残すために写真ライブラリを使用します。"
      }
    },
    "android": {
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/randish-logo-square1.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
