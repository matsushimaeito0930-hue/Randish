{
  "expo": {
    "name": "RANDISH",
    "slug": "randish",
    "version": "1.0.0",
    "scheme": "randish",
    "orientation": "portrait",
    "icon": "./assets/randish-logo-square1.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/randish-logo-square1.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8fafc"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "プロフィール画像やごはん日記の写真を選ぶために写真へのアクセスを使用します。",
          "cameraPermission": "ごはんの写真を撮ってアルバムに残すためにカメラを使用します。"
        }
      ],
      "expo-apple-authentication",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "近くのお店を探して地図ルーレットを回すために現在地を使用します。"
        }
      ],
      "expo-secure-store"
    ],
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "ごはんの写真を撮ってアルバムに残すためにカメラを使用します。",
        "NSLocationWhenInUseUsageDescription": "近くのお店を探して地図ルーレットを回すために現在地を使用します。",
        "NSPhotoLibraryUsageDescription": "プロフィール画像やごはんの写真を選ぶために写真へのアクセスを使用します。",
        "NSPhotoLibraryAddUsageDescription": "撮影したごはんの写真をアルバムに残すために写真ライブラリを使用します。"
      }
    },
    "android": {
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/randish-logo-square1.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
