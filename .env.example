HOTPEPPER_API_KEY=
GOOGLE_PLACES_API_KEY=
# Google Places is disabled by default. Enable only when intentionally testing paid fallback.
RANDISH_GOOGLE_PLACES_ENABLED=false
RANDISH_GOOGLE_PLACES_SESSION_LIMIT=30

# Use this for Supabase Postgres. Replace [YOUR-PASSWORD] locally; never commit it.
RANDISH_DATABASE_URI=postgresql://postgres.project-ref:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# Use these when enabling Supabase Auth through the Spring Boot API.
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_ANON_KEY=

# Optional: use these instead of RANDISH_DATABASE_URI when connecting Spring Boot to a managed database.
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=
