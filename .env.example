HOTPEPPER_API_KEY=
GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# Vercel serverless AI monthly report. Never expose this in the mobile/web bundle.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_REPORT_ENDPOINT=
AI_REPORT_REQUEST_TOKEN=
AI_REPORT_ALLOWED_ORIGINS=http://localhost:19006,http://127.0.0.1:19006

# Google Places is disabled by default. Enable only when intentionally testing paid fallback.
RANDISH_GOOGLE_PLACES_ENABLED=false
RANDISH_GOOGLE_PLACES_SESSION_LIMIT=30
PLACES_CACHE_TTL_SECONDS=600
PLACES_CACHE_DISTANCE_METERS=300
RANDISH_PLACES_MAX_RESULTS=20
# Development only. Keep false in production; mock places are never used when RANDISH_ENV=production.
RANDISH_PLACES_MOCK_ENABLED=false
EXPO_PUBLIC_PLACES_CACHE_TTL_SECONDS=600
EXPO_PUBLIC_PLACES_CACHE_DISTANCE_METERS=300

# Bind to all interfaces in development so Expo Go on a physical phone can reach the API.
# Set to 127.0.0.1 if you only want local PC access.
RANDISH_SERVER_ADDRESS=0.0.0.0
RANDISH_H2_CONSOLE_ENABLED=false
RANDISH_DEBUG_ENABLED=false
RANDISH_CORS_ALLOWED_ORIGINS=http://localhost:19006,http://127.0.0.1:19006,http://localhost:8081,http://127.0.0.1:8081,http://localhost:3000,http://127.0.0.1:3000
RANDISH_RATE_LIMIT_ENABLED=true
RANDISH_RATE_LIMIT_API_PER_MINUTE=180
RANDISH_RATE_LIMIT_AUTH_PER_MINUTE=20
RANDISH_RATE_LIMIT_PHOTO_PER_MINUTE=60

# Use this for Supabase Postgres. Replace [YOUR-PASSWORD] locally; never commit it.
RANDISH_DATABASE_URI=postgresql://postgres.project-ref:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# Use these when enabling Supabase Auth through the Spring Boot API.
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_ANON_KEY=
# Add this URL to Supabase Auth redirect URLs when enabling Google / Apple sign-in.
RANDISH_OAUTH_REDIRECT_URI=randish://auth/callback
# Optional mobile override. Leave blank unless you need a fixed Expo Go/Web callback.
EXPO_PUBLIC_RANDISH_OAUTH_REDIRECT_URI=

# RevenueCat public SDK keys for RANDISH PRO. These are publishable client keys, not secret server keys.
# Real iOS/Android purchases require an Expo development build or store build, not plain Expo Go.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_WEB_API_KEY=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=premium
# Keep false in production until RevenueCat webhooks update the backend subscription state.
EXPO_PUBLIC_TRUST_NATIVE_REVENUECAT_STATUS=false
# Secret value copied into RevenueCat webhook "Authorization header value".
REVENUECAT_WEBHOOK_AUTHORIZATION=

# Resend email-link registration.
# The base URL must be reachable from the mail app/browser that opens the verification link.
# onboarding@resend.dev is for development and may only send to your own verified Resend account email.
# To send to normal users, verify a domain in Resend and use a sender like RANDISH <noreply@your-domain.com>.
RESEND_API_KEY=
RESEND_FROM_EMAIL=RANDISH <onboarding@resend.dev>
RANDISH_EMAIL_VERIFICATION_BASE_URL=http://YOUR-PC-IP:8080

# Optional: use these instead of RANDISH_DATABASE_URI when connecting Spring Boot to a managed database.
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=
