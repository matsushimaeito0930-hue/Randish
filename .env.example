HOTPEPPER_API_KEY=
GOOGLE_PLACES_API_KEY=
# Google Places is disabled by default. Enable only when intentionally testing paid fallback.
RANDISH_GOOGLE_PLACES_ENABLED=false
RANDISH_GOOGLE_PLACES_SESSION_LIMIT=30

# Bind to all interfaces in development so Expo Go on a physical phone can reach the API.
# Set to 127.0.0.1 if you only want local PC access.
RANDISH_SERVER_ADDRESS=0.0.0.0
RANDISH_H2_CONSOLE_ENABLED=false
RANDISH_DEBUG_ENABLED=false
RANDISH_CORS_ALLOWED_ORIGINS=http://localhost:19006,http://127.0.0.1:19006,http://localhost:8081,http://127.0.0.1:8081,http://localhost:3000,http://127.0.0.1:3000
RANDISH_RATE_LIMIT_ENABLED=true
RANDISH_RATE_LIMIT_API_PER_MINUTE=180
RANDISH_RATE_LIMIT_AUTH_PER_MINUTE=20
RANDISH_RATE_LIMIT_PHOTO_PER_MINUTE=60

# Use this for Supabase Postgres. Replace [YOUR-PASSWORD] locally; never commit it.
RANDISH_DATABASE_URI=postgresql://postgres.project-ref:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# Use these when enabling Supabase Auth through the Spring Boot API.
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_ANON_KEY=
# Add this URL to Supabase Auth redirect URLs when enabling Google / Apple sign-in.
RANDISH_OAUTH_REDIRECT_URI=randish://auth/callback

# Optional: use these instead of RANDISH_DATABASE_URI when connecting Spring Boot to a managed database.
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=
